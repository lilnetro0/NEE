# NETRO frontend — public environment variables only.
# Copy to `.env` for local development. Never commit a real `.env`.
#
# All VITE_* values are embedded in the browser bundle. Treat them as PUBLIC.
# Never put supplier credentials, payment secrets, database URLs, or private
# API keys here. Those belong only on the NETRO backend.

# ---------------------------------------------------------------------------
# Application environment: development | preview | production
# In production, mocks are forbidden and HTTP repositories are required.
# ---------------------------------------------------------------------------
VITE_APP_ENV=development

# ---------------------------------------------------------------------------
# Absolute base URL of the NETRO backend API (no trailing slash).
# Required whenever VITE_USE_MOCKS=false (including all production builds).
# Example: https://api.netro.app
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Use in-memory mock repositories instead of HTTP.
# true  → local development / Storybook-style demos
# false → talk to NETRO backend only (never to distributors)
# Production MUST set this to false. The app will refuse to start otherwise.
# ---------------------------------------------------------------------------
VITE_USE_MOCKS=true

# ---------------------------------------------------------------------------
# Show in-app developer galleries (order scenarios, operational states).
# Forced off in production builds regardless of this value.
# ---------------------------------------------------------------------------
VITE_ENABLE_DEV_TOOLS=true

# ---------------------------------------------------------------------------
# Optional Sentry DSN for browser error reporting.
# Leave empty to disable. Never put auth tokens in Sentry breadcrumbs.
# ---------------------------------------------------------------------------
VITE_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Human-readable app version shown in about / diagnostics (e.g. 1.0.0).
# CI may inject this at build time.
# ---------------------------------------------------------------------------
VITE_APP_VERSION=1.0.0

# ---------------------------------------------------------------------------
# Git commit SHA or build identifier for release tracking.
# CI may inject this at build time (e.g. GITHUB_SHA).
# ---------------------------------------------------------------------------
VITE_BUILD_SHA=local
