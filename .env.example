# NETRO frontend — public environment variables only.
# Copy to `.env` for local development. Never commit a real `.env`.
#
# All VITE_* values are embedded in the browser bundle. Treat them as PUBLIC.
# Never put the Supabase service-role key, payment secrets, or supplier credentials here.

# ---------------------------------------------------------------------------
# Application environment: development | preview | production
# ---------------------------------------------------------------------------
VITE_APP_ENV=development

# ---------------------------------------------------------------------------
# Supabase project (Settings → API)
# ---------------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# ---------------------------------------------------------------------------
# Show in-app developer galleries (order scenarios, operational states).
# Forced off in production builds regardless of this value.
# ---------------------------------------------------------------------------
VITE_ENABLE_DEV_TOOLS=true

# ---------------------------------------------------------------------------
# Optional Sentry DSN for browser error reporting.
# ---------------------------------------------------------------------------
VITE_SENTRY_DSN=

# ---------------------------------------------------------------------------
# Human-readable app version / build identifier
# ---------------------------------------------------------------------------
VITE_APP_VERSION=1.0.0
VITE_BUILD_SHA=local
